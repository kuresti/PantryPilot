@namespace PantryPilot.Components.Layout
@using Microsoft.CodeAnalysis.CSharp
@using PantryPilot.Components.ReusableUI
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using PantryPilot.Models
@using SQLitePCL
@* This is the side-bar containing the Navigation Menu *@

@implements IDisposable
@inject NavigationManager NavigationManager
@inject UserManager<ApplicationUser> UserManager

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">PantryPilot</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="search-wrapper">
    <SearchDropdown CustomClass="rounded-search"/>
</div>

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            @* Match.All means it only highlights if the URL is exactly "/" *@
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="menu">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Menu
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="grocerylist">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Groceries
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="recipelist">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Recipes
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="addrecipe">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Recipe Form
            </NavLink>
        </div>

        @* This section is the Login/Logout/Register section.
           The Login and Register links will only show if a user
           is NOT authenticated. The Logout link will show if the
           user IS authenticated. *@
        
            <AuthorizeView>
                <NotAuthorized>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="/Account/Register">
                            <span class="bi bi-person-plus-fill-nav-menu" aria-hidden="true"></span> Register
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="/Account/Login">
                            <span aria-hidden="true"></span> Login
                        </NavLink>
                    </div>
                </NotAuthorized>

                <Authorized Context="authState">

                    <div class="nav-item px-3">
                        <span class="nav-link  text-light">
                            @* "@authState.User" gives access to the AuthenticationState
                               which contains an object called ClaimsPrincipal. This object
                               contains Identity.Name, Claims, Roles. That is how the line
                               below can print the user's name. *@
                            Logged in as: 👤 @(displayName ?? authState.User.Identity?.Name)
                        </span>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="/Account/Manage/Index">
                            <span aria-hidden="true"></span> Account
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                       <form method="post" action="/Account/Logout">
                            <AntiforgeryToken />
                            <input type="hidden" name="returnUrl" value="" />
                            <button type="submit" class="nav-link btn btn-link text-start w-100">
                                Logout
                            </button>
                       </form>

                    </div>
                </Authorized>
            </AuthorizeView>
        
    </nav>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }
    private string? currentUrl;
    private string? displayName;
    protected override async Task OnInitializedAsync()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
        await LoadDisplayNameAsync();
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        await LoadDisplayNameAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadDisplayNameAsync()
    {
        if (AuthenticationStateTask is null)
        {
            displayName = null;
            return;
        }

        var authState = await AuthenticationStateTask;
        var principal = authState.User;

        if (principal.Identity?.IsAuthenticated != true)
        {
            displayName = null;
            return;
        }

        var user = await UserManager.GetUserAsync(principal);
        displayName = user?.Name;
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

}