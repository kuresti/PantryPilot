@page "/menu"
@using PantryPilot.Components.ReusableUI
@rendermode InteractiveServer

@* Added to prevent non-authenticated users
   from viewing this page *@
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@* These are needed for menu planning feature *@
@using PantryPilot.Models
@* @using PantryPilot.Components.MenuPlanner *@
@using PantryPilot.Services.Interfaces
@* @using System.ComponentModel.Design *@
@using PantryPilot.Components.ReusableUI

@inject IRecipeService RecipeService
@inject IMenuService MenuService 
@inject NavigationManager NavigationManager

<PageTitle>Menu</PageTitle>

<h3>Menu</h3>

<div class="planner-layout">
    <MenuRecipeList Recipes="recipes"   
                OnDragStarted="HandleDragStarted" />

    <div class="menu-container">
        <header class="menu-header">
            <p class="tagline">Tagline</p>
            <h1 class="main-title">Menu</h1>
            <p class="description">Drag recipes into Breakfast, Lunch, and Dinner.</p>

            <div class="view-switcher">
                <button class="view-btn active">Daily</button>
                <button class="view-btn">Weekly</button>
                <button class="view-btn">Monthly</button>
            </div>

            <p class="current-date">Date: <span>@selectedDate.ToString("MMMM d, yyyy")</span></p>
        </header>

        <div class="meal-grid">
            <MealCard Date="selectedDate"
                    MealType="MealType.Breakfast"
                    RecipeId="breakfastRecipeId"
                    OnRecipeDropped="HandleRecipeDropped"
                    OnRecipeClicked="HandleRecipeClicked"/>
            
            <MealCard Date="selectedDate"
                    MealType="MealType.Lunch"
                    RecipeId="lunchRecipeId"
                    OnRecipeDropped="HandleRecipeDropped"
                    OnRecipeClicked="HandleRecipeClicked" />
            
            <MealCard Date="selectedDate"
                    MealType="MealType.Dinner"
                    RecipeId="dinnerRecipeId"
                    OnRecipeDropped="HandleRecipeDropped"
                    OnRecipeClicked="HandleRecipeClicked" />
        </div>

        <RecipeDetailsPanel SelectedRecipe="selectedRecipe" />
    </div>
</div>

@code {
    private List<Recipe> recipes = new();
    private Recipe? selectedRecipe;
    private int? draggedRecipeId;

    private DateOnly selectedDate = DateOnly.FromDateTime(DateTime.Today);

    // Temporary local state until MenuService is implemented
    // TODO: Replace temporary meal assignment state with MenuService when implemented
    private int? breakfastRecipeId;
    private int? lunchRecipeId;
    private int? dinnerRecipeId;

    protected override async Task OnInitializedAsync()
    {
        recipes = await RecipeService.GetUserRecipes();

        // Temporary RecipeList for testing
        // Todo: Remove when RecipeList is seeded
        if (!recipes.Any())
        {
            recipes = new List<Recipe>
                {
                    new Recipe { Id = 101, Name = "Test Pancakes", PrepTime = 10, CookTime = 5, Servings = 2},
                    new Recipe { Id = 102, Name = "Test Salad", PrepTime = 5, CookTime = 0, Servings = 1},
                    new Recipe { Id = 103, Name = "Test Pasta", PrepTime = 12, CookTime = 15, Servings = 3}
                };
        }
    }

    private Task HandleDragStarted(int recipeId)
    {
        // For testing
        Console.WriteLine($"Dragging recipe id: {recipeId}");
        draggedRecipeId = recipeId;

        return Task.CompletedTask;
    }

    private Task HandleRecipeDropped((DateOnly date, MealType mealType) args)
    {
        // For Testing
        Console.WriteLine($"Parent received drop for {args.mealType}, draggedRecipeId={draggedRecipeId}");
        if (draggedRecipeId is null)
            return Task.CompletedTask;

        switch (args.mealType)
        {
            case MealType.Breakfast:
                breakfastRecipeId = draggedRecipeId.Value;
                break;

            case MealType.Lunch:
                lunchRecipeId = draggedRecipeId.Value;
                break;

            case MealType.Dinner:
                dinnerRecipeId = draggedRecipeId.Value;
                break;
        }

        draggedRecipeId = null;
        return Task.CompletedTask;
    }

    private async Task HandleRecipeClicked(int recipeId)
    {
        selectedRecipe = await RecipeService.GetRecipe(recipeId);
    }

}
