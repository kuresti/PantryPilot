@page "/menu"
@rendermode InteractiveServer

@using PantryPilot.Components.ReusableUI
@using PantryPilot.Models
@using PantryPilot.Services.Interfaces


@* Added to prevent non-authenticated users
   from viewing this page *@
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize];
@inject NavigationManager NavigationManager
@inject IRecipeService RecipeService
@inject IWeeklyMenuService WeeklyMenuService

<PageTitle>Menu</PageTitle>
<div class="planner-layout">
    <MenuRecipeList Recipes="recipes"
                OnDragStarted="HandleDragStarted" />

<div class="menu-container">
    <header class="menu-header">
        <p class="tagline">Plan your meals</p>
        <h1 class="main-title">Menu</h1>
        <p class="description">Drag recipes into Breakfast, Lunch, and Dinner.</p>

        <div class="view-switcher">
            <button type="button" 
                    class="view-btn @(currentView == MenuViewMode.Daily ? "active" : "")"
                    @onclick="() => SetView(MenuViewMode.Daily)">
                Daily
            </button>

            <button type="button"
                    class="view-btn @(currentView == MenuViewMode.Weekly ? "active" : "")"
                    @onclick="() => SetView(MenuViewMode.Weekly)">
                Weekly    
            </button>

            <button type="button"
                    class="view-btn @(currentView == MenuViewMode.Monthly ? "active" : "")"
                    @onclick="() => SetView(MenuViewMode.Monthly)">
                Monthly    
            </button>
        </div>

        <p class="current-date">
            Date: <span>@selectedDate.ToString("MMMM d, yyyy")</span>
        </p>
    </header>

@if (currentView == MenuViewMode.Daily)
{
            <div class="meal-grid">
                <DayMenuPanel Date="selectedDate"
                MenuDay="selectedMenuDay"
                OnRecipeDropped="HandleRecipeDropped"
                OnRecipeClicked="HandleRecipeClicked" />
            </div>
}
else if (currentView == MenuViewMode.Weekly)
{
    <div class="weekly-grid">
        @if (weeklyMenu is not null)
        {
            @foreach (var day in weeklyMenu.Days.OrderBy(d => d.Date))
            {
                <DayMenuPanel Date="day.Date"
                              MenuDay="day"
                              OnRecipeDropped="HandleRecipeDropped"
                              OnRecipeClicked="HandleRecipeClicked" />
            }
        }
    </div>
}
else if (currentView == MenuViewMode.Monthly)
{
    <MonthlyCalendarGrid CurrentMonth="currentMonth"
                         SelectedDate="selectedDate"
                         MenuDays="weeklyMenu?.Days ?? new List<MenuDay>()"
                         Recipes="recipes"
                         OnDateSelected="SelectDate"
                         OnRecipeClicked="HandleRecipeClicked"
                         OnPreviousMonth="PreviousMonth"
                         OnNextMonth="NextMonth" />
}
        <RecipeDetailsPanel SelectedRecipe="selectedRecipe" />
    </div>
</div>

@code {
    private List<Recipe> recipes = new();
    private Recipe? selectedRecipe;
    private int? draggedRecipeId;

    private DateOnly selectedDate = new DateOnly(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateOnly currentMonth = new DateOnly(DateTime.Today.Year, DateTime.Today.Month, 1);

    private WeeklyMenu? weeklyMenu;
    private MenuDay? selectedMenuDay;

    private MenuViewMode currentView = MenuViewMode.Daily;

    // lifecycle method that calls services, loads data
    // initializes state. 
    protected override async Task OnInitializedAsync()
    {
        recipes = await RecipeService.GetUserRecipes();

        int userId = await RecipeService.GetCurrentUserId();
        weeklyMenu = await WeeklyMenuService.GetCurrentWeeklyMenuForUserAsync(userId);

        if (weeklyMenu is not null)
        {
            selectedMenuDay = weeklyMenu.Days.FirstOrDefault(d => d.Date == selectedDate);
        }
    }

    private void SetView(MenuViewMode viewMode)
    {
        currentView = viewMode;
    }

    private Task HandleDragStarted(int recipeId)
    {
        draggedRecipeId = recipeId;
        return Task.CompletedTask;
    }

    // Control logic for drag and drop
    // Saves the action to the database
    // Reloads the menu
    // Updates the UI
    private async Task HandleRecipeDropped((DateOnly date, MealType mealType) args)
    {
        // Method takes date (what date?), and mealType (what meal slot?)
        // information is sent so parent knows the user dropped the recipe
        // on specific date and mealType

        // Check to see if there is a draggedRecipeId
        // If not nothing will happen.
        if (draggedRecipeId is null)
        {
            return;
        }

        // Gets the userId because menus are assigned per user
        int userId = await RecipeService.GetCurrentUserId();

        // UI action becomes a database state
        await WeeklyMenuService.AssignRecipeToMealAsync(
            userId,
            args.date,
            args.mealType,
            draggedRecipeId.Value);

        // The menu is reloaded from the database
        weeklyMenu = await WeeklyMenuService.GetCurrentWeeklyMenuForUserAsync(userId);


        if (weeklyMenu is not null)
        {
            // The selected day is updated
            selectedMenuDay = weeklyMenu.Days.FirstOrDefault(d => d.Date == selectedDate);
        }

        // Clears the drag state.
        draggedRecipeId = null;
    }

    // List to get days of the month
    private List<DateOnly> GetDaysInMonth(DateOnly monthStart)
    {
        var days = new List<DateOnly>();
        int daysInMonth = DateTime.DaysInMonth(monthStart.Year, monthStart.Month);

        for (int day = 1; day <= daysInMonth; day++)
        {
            days.Add(new DateOnly(monthStart.Year, monthStart.Month, day));
        }

        return days;
    }

    // Helper method to find the MenuDay
    private MenuDay? GetMenuDay(DateOnly date)
    {
        return weeklyMenu?.Days.FirstOrDefault(d => d.Date == date);
    }

    // User clicks recipe in meal card
    // method: loads recipe from the database,
    // then sets the selectedRecipe and updates
    // Details panel
    private async Task HandleRecipeClicked(int recipeId)
    {
        selectedRecipe = await RecipeService.GetRecipe(recipeId);
    }

    // Helper method to get recipe name
    private string GetRecipeName(int recipeId)
    {
        return recipes.FirstOrDefault(r => r.Id == recipeId)?.Name ?? "Unknown";
    }

    // 
    private void SelectDate(DateOnly date)
    {
        selectedDate = date;
        selectedMenuDay = weeklyMenu?.Days.FirstOrDefault(d => d.Date == selectedDate);
        currentView = MenuViewMode.Daily;
    }

    // Helper method to get the previous month
    private void PreviousMonth()
    {
        currentMonth = currentMonth.AddMonths(-1);
    }

    // Helper method to get the next month
    private void NextMonth()
    {
        currentMonth = currentMonth.AddMonths(1);
    }

    // Enum for switching between Daily, Weekly, and Monthly recipe views
    public enum MenuViewMode
    {
        Daily,
        Weekly,
        Monthly
    }
}