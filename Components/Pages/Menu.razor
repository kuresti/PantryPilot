@page "/menu"
@using Microsoft.AspNetCore.Authorization
@using PantryPilot.Components.ReusableUI
@rendermode InteractiveServer

@* Added to mark the page as protected
   Allows only logged in user to access the page *@
@attribute [Authorize]
@inject NavigationManager NavigationManager

<PageTitle>Menu</PageTitle>

<div class="menu-container">
    <header class="menu-header">
        <p class="tagline">Tagline</p>
        <h1 class="main-title">Menu</h1>
        <p class="description">Lorem ipsum dolor sit amet et delectus accommodare his consul copiosae.</p>

        <div class="view-switcher">
            <button class="view-btn active">Daily</button>
            <button class="view-btn">Weekly</button>
            <button class="view-btn">Monthly</button>
        </div>

        <p class="current-date">Date: <span>April 10, 2026</span></p>
    </header>

    <div class="meal-grid">
        <MealCard Type="Breakfast"
                  Name="Blueberry Pancakes"
                  Features="@(new List<string> { "High Protein", "Gluten Free", "15 mins" })" />
        
        <MealCard Type="Lunch" 
                  Name="Chicken Caesar" 
                  Features="@(new List<string> { "Fresh Greens", "Low Carb", "10 mins" })" />
        
        <MealCard Type="Dinner" 
                  Name="Grilled Salmon" 
                  Features="@(new List<string> { "Omega-3", "Heart Healthy", "25 mins" })" />
    </div>
</div>

@code {
    
}
