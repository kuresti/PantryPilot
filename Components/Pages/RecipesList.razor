@page "/recipelist"
@rendermode InteractiveServer // for the header navigation
@using PantryPilot.Services.Interfaces;
@using PantryPilot.Models

@* Added to prevent non-authenticated users
   from viewing this page *@
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize];
@inject IRecipeService RecipeService
@inject NavigationManager NavigationManager

<PageTitle>Recipe List</PageTitle>

<div class="recipe-list-page">
    <div class="recipe-list-header">
        <h1>Recipe List</h1>
        <button class="btn-add-recipe" @onclick="GoToAddRecipe">+ Add Recipe</button>
    </div>

    @if (recipes == null)
    {
        <p class="loading-msg"><em>Loading...</em></p>
    }
    else if (!recipes.Any())
    {
        <div class="empty-state">
            <p>No recipes yet.</p>
            <button class="btn-add-recipe" @onclick="GoToAddRecipe">Add your first recipe</button>
        </div>
    }
    else
    {
        <div class="recipe-cards">
            @foreach (var recipe in recipes)
            {
                <div class="recipe-card" @onclick="() => ViewRecipe(recipe.Id)">
                    @* Left color accent *@
                    <div class="card-accent"></div>

                    <div class="card-body">
                        <div class="card-top">
                            <h2 class="card-name">@recipe.Name</h2>
                            <div class="card-actions" @onclick:stopPropagation="true">
                                <button class="btn-edit" @onclick="() => EditRecipe(recipe.Id)">Edit</button>
                                <button class="btn-delete" @onclick="() => DeleteRecipe(recipe.Id)">Delete</button>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(recipe.Description))
                        {
                            <p class="card-description">@recipe.Description</p>
                        }

                        <div class="card-meta">
                            <span class="meta-badge">⏱ Prep @recipe.PrepTime min</span>
                            <span class="meta-badge">🍳 Cook @recipe.CookTime min</span>
                            <span class="meta-badge">🍽 @recipe.Servings serving@(recipe.Servings == 1 ? "" : "s")</span>
                        </div>

                        @if (recipe.RecipeIngredients != null && recipe.RecipeIngredients.Any())
                        {
                            <ul class="card-ingredients">
                                @foreach (var ri in recipe.RecipeIngredients.Take(4))
                                {
                                    <li>@(ri.Ingredient?.Name ?? "Ingredient")</li>
                                }
                                @if (recipe.RecipeIngredients.Count > 4)
                                {
                                    <li class="more-indicator">+@(recipe.RecipeIngredients.Count - 4) more</li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Recipe>? recipes;

    protected override async Task OnInitializedAsync()
    {
        recipes = await RecipeService.GetUserRecipes();
    }

    private void GoToAddRecipe() => NavigationManager.NavigateTo("/addrecipe");
    private void EditRecipe(int id) => NavigationManager.NavigateTo($"/addrecipe/{id}");
    private void ViewRecipe(int id) => NavigationManager.NavigateTo($"/recipe/{id}");

    private async Task DeleteRecipe(int id)
    {
        var success = await RecipeService.DeleteRecipe(id);
        if (success)
        {
            recipes = await RecipeService.GetUserRecipes();
        }
    }
}