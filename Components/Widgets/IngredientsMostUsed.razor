@inject PantryPilot.Services.DashboardStateService DashboardService
@implements IDisposable
@using MudBlazor

<MudCard Outlined="true" Class="ma-4" Style="width: 300px;">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">Ingredients Used Most</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        <MudList T="string">
            @{ int i = 1; }
            @foreach (var item in new[] { "food", "snack", "meal" })
            {
                <MudListItem Text="@($"{i++}. {item}")" />
            }
        </MudList>
    </MudCardContent>
</MudCard>

@code {
    protected override void OnInitialized()
    {
        // Subscribe to changes so the UI refreshes when a widget is toggled
        DashboardService.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        //Unsubscribe to prevent memory leaks
        DashboardService.OnChange -= StateHasChanged;
    }
}