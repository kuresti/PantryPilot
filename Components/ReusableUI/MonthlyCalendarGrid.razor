@* This component displays Monthly menus. It
   does not allow for drag and drop. Recipes
   can be selected. *@

@using PantryPilot.Models

<div class="monthly-view">
    <div class="month-header">
        <button type="button"
                class="month-nav-btn"
                @onclick="() => OnPreviousMonth.InvokeAsync()">
            Previous Month
        </button>

        <h3>@CurrentMonth.ToString("MMMM yyyy")</h3>

        <button type="button"
                class="month-nav-btn"
                @onclick="() => OnNextMonth.InvokeAsync()">
            Next Month
        </button>
    </div>

    <div class="weekday-header">
        <div>Sun</div>
        <div>Mon</div>
        <div>Tue</div>
        <div>Wed</div>
        <div>Thu</div>
        <div>Fri</div>
        <div>Sat</div>
    </div>

    <div class="monthly-grid">
        @foreach (var cell in GetCalendarCells())
        {
            if (cell is null)
            {
                <div class="month-cell empty-cell"></div>
            }
            else
            {
                var dayMenu = GetMenuDay(cell.Value);

                <div class="month-cell @(cell.Value == SelectedDate ? "selected-day" : "")">
                    <div class="month-cell-header">
                        <button type="button"
                                class="day-number-button"
                                @onclick="() => OnDateSelected.InvokeAsync(cell.Value)">
                            @cell.Value.Day
                        </button>
                    </div>

                    <div class="month-cell-body">
                        <div class="meal-summary">
                            <strong>B:</strong>
                            @if (dayMenu?.BreakfastRecipeId is int breakfastId)
                            {
                                <button type="button"
                                        class="recipe-link-button"
                                        @onclick="() => OnRecipeClicked.InvokeAsync(breakfastId)">
                                     @GetRecipeName(breakfastId)   
                                </button>
                            }
                        </div>

                        <div class="meal-summary">
                            <strong>L:</strong>
                            @if (dayMenu?.LunchRecipeId is int lunchId)
                            {
                                <button type="button"
                                        class="recipe-link-button"
                                        @onclick="() => OnRecipeClicked.InvokeAsync(lunchId)">
                                    @GetRecipeName(lunchId)    
                                </button>
                            }
                        </div>

                        <div class="meal-summary">
                            <strong>D:</strong>
                            @if (dayMenu?.DinnerRecipeId is int dinnerId)
                            {
                                <button type="button"
                                        class="recipe-link-button"
                                        @onclick="() => OnRecipeClicked.InvokeAsync(dinnerId)">
                                    @GetRecipeName(dinnerId)   
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public DateOnly CurrentMonth { get; set; }
    [Parameter] public DateOnly SelectedDate { get; set; }
    [Parameter] public List<MenuDay> MenuDays { get; set; } = new();
    [Parameter] public List<Recipe> Recipes { get; set; } = new();

    [Parameter] public EventCallback<DateOnly> OnDateSelected { get; set; }
    [Parameter] public EventCallback<int> OnRecipeClicked { get; set; }
    [Parameter] public EventCallback OnPreviousMonth { get; set; }
    [Parameter] public EventCallback OnNextMonth { get; set; }

    private List<DateOnly?> GetCalendarCells()
    {
        var cells = new List<DateOnly?>();

        var firstDayOfMonth = new DateOnly(CurrentMonth.Year, CurrentMonth.Month, 1);
        int daysInMonth = DateTime.DaysInMonth(CurrentMonth.Year, CurrentMonth.Month);

        int leadingBlanks = (int)firstDayOfMonth.DayOfWeek;

        for (int i = 0; i < leadingBlanks; i++)
        {
            cells.Add(null);
        }

        for (int day = 1; day <= daysInMonth; day++)
        {
            cells.Add(new DateOnly(CurrentMonth.Year, CurrentMonth.Month, day));
        }

        while (cells.Count % 7 != 0)
        {
            cells.Add(null);
        }

        return cells;
    }

    private MenuDay? GetMenuDay(DateOnly date)
    {
        return MenuDays.FirstOrDefault(d => d.Date == date);
    }

    private string GetRecipeName(int recipeId)
    {
        return Recipes.FirstOrDefault(r => r.Id == recipeId)?.Name ?? "Unknown";
    }
    
}